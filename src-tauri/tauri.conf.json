{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "artimonist",
  "version": "0.2.0",
  "identifier": "org.artimonist",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Artimonist - A tool for generating mnemonics and wallets.",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/192x192.png",
      "icons/512x512.png",
      "icons/icon.ico"
    ]
  }
}